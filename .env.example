# Optional power-user config. You normally DON'T need this — the in-app setup
# wizard collects these and stores them in the local database instead.
#
# If you do set them here (or in docker-compose), they seed the settings on
# first startup so you can skip the wizard.

# Your Renshuu read API key (Renshuu > Resources > API).
RENSHUU_API_KEY=

# Review reminders are delivered as PWA push notifications — install the app to
# your home screen and enable notifications from the setup wizard or Settings.
# VAPID keys are generated automatically on first use and stored in the DB.
#
# Optional: the "sub" claim sent with each push (a mailto: or https: URL a push
# service can use to contact you about your app). Defaults to a placeholder.
# VAPID_SUBJECT=mailto:you@example.com

# --- Public hosting (Railway etc.) ----------------------------------------
# Password that gates the whole site. REQUIRED when hosting publicly — without
# it the dashboard is open to anyone with the URL. Leave unset for a private,
# local-only instance (auth disabled).
APP_PASSWORD=

# Random secret used to sign the login session cookie. Set a stable value so
# logins survive restarts/redeploys (otherwise a random one is used per boot).
APP_SECRET=

# Mark the session cookie Secure (HTTPS-only). Default true. Set to "false" for
# local http development so the cookie is accepted.
# APP_COOKIE_SECURE=true
